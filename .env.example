# Copia este fichero a .env y ajusta lo que necesites.

# ---------------------
# Ollama externo (Windows host)
# ---------------------
# Si la IP cambia, actualiza esto:
#   ip route show | grep -i default | awk '{ print $3 }'
OLLAMA_EXTERNAL_URL=http://172.21.192.1:11434

# ---------------------
# Modelo
# ---------------------
PIPELINE_MODEL=gemma4:26b

# ---------------------
# Concurrencia
# ---------------------
PIPELINE_MAX_CONCURRENT=2

# ---------------------
# Puertos
# ---------------------
ORCHESTRATOR_PORT=8000

# ---------------------
# Límites por contenedor-agente
# ---------------------
PIPELINE_AGENT_MEM=4g
PIPELINE_AGENT_CPUS=2.0
PIPELINE_AGENT_TIMEOUT=2400

# ---------------------
# GID del grupo docker del host (para socket)
# ---------------------
# Averiguar con: getent group docker | cut -d: -f3
DOCKER_GID=988

# ---------------------
# Rutas host (opcional)
# ---------------------
# PIPELINE_REPOS_HOST=/home/javier/dev
