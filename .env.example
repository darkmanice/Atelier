# Copy this file to .env and tweak as needed.

# ---------------------
# LLM provider
# ---------------------
# API key, base URL, and model are chosen PER TASK from the UI. There are no
# global defaults: the key lives only in the orchestrator's memory, is handed
# to the worker once via an internal token, and lives in the agent container's
# env for the duration of its run.
#
# UI presets (purely cosmetic, filled in from the front):
#   - NVIDIA NIM:     https://integrate.api.nvidia.com/v1
#   - OpenAI:         https://api.openai.com/v1
#   - OpenRouter:     https://openrouter.ai/api/v1
#   - Local Ollama:   http://172.21.192.1:11434/v1  (WSL → Windows gateway)
#
# If you want local Ollama as the default, adjust the UI preset to your IP:
#   ip route show | grep -i default | awk '{ print $3 }'

# ---------------------
# Internal orchestrator ↔ worker secret
# ---------------------
# Protects the /internal/consume-secret endpoint. Generate a long, unique
# value and NEVER share it. Example:
#   openssl rand -hex 32
INTERNAL_API_TOKEN=CHANGE_ME_RUN_openssl_rand_hex_32

# ---------------------
# Master key for stored LLM providers (AES-GCM)
# ---------------------
# If empty, the "stored providers" feature is disabled (the one-shot flow
# still works). If set:
#   - 32 hex bytes (64 chars). Generate with:  openssl rand -hex 32
#   - If you LOSE or CHANGE it, every stored API key becomes unreadable
#     (game over). Back it up alongside your .env.
MASTER_ENCRYPTION_KEY=

# ---------------------
# Default LLM model shown in the UI (required; can be overridden per task).
# V2 uses the OpenHands SDK, which calls models with tool-calling. The
# model id MUST be one your endpoint exposes AND that supports tools.
# Examples:
#   qwen3.6:latest          (Ollama, local — recommended default)
#   qwen2.5-coder:32b       (Ollama, local — solid coder model)
#   devstral                (Ollama, local — Mistral's coding agent model)
#   meta/llama-3.3-70b-instruct
#   gpt-4o-mini
# ---------------------
DEFAULT_MODEL=qwen3.6:latest

# ---------------------
# Concurrency
# ---------------------
MAX_CONCURRENT_TASKS=2

# ---------------------
# Ports
# ---------------------
ORCHESTRATOR_PORT=8000

# ---------------------
# Resource limits for the ephemeral test runner containers.
# (Kept under the AGENT_* names for compatibility with the runner code.)
# ---------------------
AGENT_MEM_LIMIT=4g
AGENT_CPU_LIMIT=2.0

# ---------------------
# Maximum agent loop iterations per OpenHands session. Each iteration
# is roughly one LLM call + one tool execution. Bound the wall-clock
# of a single phase with slow local models. 30 is a sane default.
# ---------------------
OPENHANDS_MAX_ITERATIONS=30

# ---------------------
# Host UID / GID
# ---------------------
# Containers run with these UID/GID so every file they create on bind-mounts
# is owned by your host user. Run scripts/setup.sh to auto-fill, or set
# manually with: id -u / id -g
HOST_UID=
HOST_GID=

# ---------------------
# Host docker group GID (for the socket)
# ---------------------
# Worker uses this as a supplementary group to access /var/run/docker.sock.
# Run scripts/setup.sh to auto-fill, or set with: getent group docker | cut -d: -f3
DOCKER_GID=

