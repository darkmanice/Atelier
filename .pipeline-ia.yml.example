# pipeline-ia config. Copia este fichero a la raíz de TU repo (no del pipeline-ia)
# con el nombre .pipeline-ia.yml y ajusta los comandos a tu proyecto.
#
# TODAS las secciones son opcionales. Si omites una, esa fase se saltea con warning.
# Si omites este fichero entero, el pipeline no ejecutará tests pero funcionará.

# --- Instalación de dependencias ---
# Se ejecuta UNA vez al inicio del pipeline, antes del implementer.
# Si lo omites, los tests asumen que las deps ya están en la imagen del runner.
install:
  command: "pip install -r requirements.txt && pip install -e ."
  timeout: 300

# --- Quick tests: GATE antes del reviewer ---
# Si fallan, el implementer recibe feedback y reintenta (hasta MAX_RETRY_ATTEMPTS).
# Idealmente rápidos: unit tests, linter, type check.
quick_tests:
  command: "pytest tests/unit -x --tb=short && ruff check ."
  timeout: 120

# --- Full tests: GATE antes de E2E ---
# Integración, tests más lentos, cobertura.
full_tests:
  command: "pytest tests/ --cov=src --cov-fail-under=80"
  timeout: 300

# --- E2E: GATE final ---
# setup/teardown se ejecutan desde el worker de Prefect (tiene acceso a Docker del host).
# El comando de test corre en un contenedor con Playwright preinstalado.
e2e_tests:
  setup: "docker compose -f docker-compose.test.yml up -d --wait"
  command: "pytest tests/e2e"
  teardown: "docker compose -f docker-compose.test.yml down -v"
  timeout: 900
